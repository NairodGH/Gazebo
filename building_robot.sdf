<?xml version="1.0"?>
<!-- https://gazebosim.org/docs/latest/tutorials/ -->
<sdf version="1.10">
    <world name="car_world">
        <!-- define each simulation step to be 1 millisecond (smaller=more accurate but more
        intensive) and simulation runs at real time speed, type="ignored" simply is a human-readable
        placeholder for "let physics plugin (bellow) choose" -->
        <physics name="1ms" type="ignored">
            <max_step_size>0.001</max_step_size>
            <real_time_factor>1.0</real_time_factor>
        </physics>
        <!-- everything in gazebo is a plugin, even the scene, stats, controls, entity tree... (which are included by default even if not
        added) and they're all customizable -->
        <!-- makes objects move, fall, and collide -->
        <plugin
            filename="gz-sim-physics-system"
            name="gz::sim::systems::Physics">
        </plugin>
        <!-- move/modify objects in the simulation at runtime via GUI or commands -->
        <plugin
            filename="gz-sim-user-commands-system"
            name="gz::sim::systems::UserCommands">
        </plugin>
        <!-- streams the scene state to the GUI and external tools so they can visualize it -->
        <plugin
            filename="gz-sim-scene-broadcaster-system"
            name="gz::sim::systems::SceneBroadcaster">
        </plugin>
        <!-- outputs the orientation of our robot in quaternions, the angular_velocity in the three axes (X, Y, Z), and the
            linear_acceleration in the three axes, adds imu sensor type to retrieve them from topic (gz topic -e -t /imu) -->
        <plugin filename="gz-sim-imu-system"
            name="gz::sim::systems::Imu">
        </plugin>
        <!-- sun in the sky casting a fading light downwards which creates shadows -->
        <light type="directional" name="sun">
            <cast_shadows>true</cast_shadows>
            <pose>0 0 10 0 0 0</pose>
            <diffuse>0.8 0.8 0.8 1</diffuse> <!-- main light color hitting surfaces -->
            <specular>0.2 0.2 0.2 1</specular> <!-- shine color on reflective surfaces -->
            <attenuation> <!-- intensity=1/(constant+linear*d+quadratic*d²) -->
                <range>1000</range>
                <constant>0.9</constant>
                <linear>0.01</linear>
                <quadratic>0.001</quadratic>
            </attenuation>
            <direction>-0.5 0.1 -0.9</direction>
        </light>
        <!-- model is an object in the world, static means immobile, link is a rigid body inside a
        model (can have multiple links, connected by joints), each link has a collision (same size as
        visual if simple but can be simpler to gain perf) and a visual (rendered appearance).
        here's the plane at default (unspecified) position/rotation 0 in world coordinates -->
        <model name="ground_plane">
            <static>true</static>
            <link name="link">
                <collision name="collision">
                    <geometry>
                        <plane>
                            <normal>0 0 1</normal>
                        </plane>
                    </geometry>
                </collision>
                <visual name="visual">
                    <geometry>
                        <plane>
                            <normal>0 0 1</normal>
                            <size>100 100</size>
                        </plane>
                    </geometry>
                    <material>
                        <ambient>0.8 0.8 0.8 1</ambient> <!-- color under indirect/ambient light -->
                        <diffuse>0.8 0.8 0.8 1</diffuse>
                        <specular>0.8 0.8 0.8 1</specular>
                    </material>
                </visual>
            </link>
        </model>
        <model name='vehicle_blue' canonical_link='chassis'>
            <link name='chassis'>
                <!-- position the chassis so the model origin sits roughly at the car's geometric
                center, and lift it a bit to make room for the wheels underneath -->
                <pose relative_to='__model__'>0.5 0 0.4 0 0 0</pose>
                <inertial> <!-- how mass is distributed inside the object/how it resists rotational motion -->
                    <mass>1.14395</mass> <!-- in kg -->
                    <!-- ixx=resistance to rotation around X axis, iyy=Y axis izz=Z axis
                        ixy,ixz,iyz = Cross terms, how rotation on one axis affects another
                        for a solid box with dimensions x=2.0, y=1.0, z=0.5 and mass m=1.14395:
                        ixx = (1/12) * m * (y² + z²) = (1/12) * 1.14395 * (1.0 + 0.25) = 0.095329
                        iyy = (1/12) * m * (x² + z²) = (1/12) * 1.14395 * (4.0 + 0.25) = 0.381317
                        izz = (1/12) * m * (x² + y²) = (1/12) * 1.14395 * (4.0 + 1.0)  = 0.476646
                        each diagonal value uses the two axes perpendicular to the rotation axis
                        because resistance to spinning around an axis depends on how far mass is spread in the other two directions
                        cross terms are 0 because a uniform box has symmetric mass distribution along all axes -->
                    <inertia>
                        <ixx>0.095329</ixx>
                        <ixy>0</ixy>
                        <ixz>0</ixz>
                        <iyy>0.381317</iyy>
                        <iyz>0</iyz>
                        <izz>0.476646</izz>
                    </inertia>
                </inertial>
                <visual name='visual'>
                    <geometry>
                        <box>
                            <size>2.0 1.0 0.5</size>
                        </box>
                    </geometry>
                    <material>
                        <ambient>0.0 0.0 1.0 1</ambient>
                        <diffuse>0.0 0.0 1.0 1</diffuse>
                        <specular>0.0 0.0 1.0 1</specular>
                    </material>
                </visual>
                <collision name='collision'>
                    <geometry>
                        <box>
                            <size>2.0 1.0 0.5</size>
                        </box>
                    </geometry>
                </collision>
                <!-- produce acceleration/gyroscope data -->
                <sensor name="imu_sensor" type="imu">
                    <always_on>1</always_on>
                    <update_rate>1</update_rate>
                    <visualize>true</visualize>
                    <topic>imu</topic>
                </sensor>
            </link>
            <link name='left_wheel'>
                <!-- position the cylinder at the back of the chassis, rotated 90° (in radians) to look like a wheel -->
                <pose relative_to="chassis">-0.5 0.6 0 -1.5707 0 0</pose>
                <inertial>
                    <mass>1</mass>
                    <inertia>
                        <ixx>0.043333</ixx>
                        <ixy>0</ixy>
                        <ixz>0</ixz>
                        <iyy>0.043333</iyy>
                        <iyz>0</iyz>
                        <izz>0.08</izz>
                    </inertia>
                </inertial>
                <visual name='visual'>
                    <geometry>
                        <cylinder>
                            <radius>0.4</radius>
                            <length>0.2</length>
                        </cylinder>
                    </geometry>
                    <material>
                        <ambient>1.0 0.0 0.0 1</ambient>
                        <diffuse>1.0 0.0 0.0 1</diffuse>
                        <specular>1.0 0.0 0.0 1</specular>
                    </material>
                </visual>
                <collision name='collision'>
                    <geometry>
                        <cylinder>
                            <radius>0.4</radius>
                            <length>0.2</length>
                        </cylinder>
                    </geometry>
                </collision>
            </link>
            <link name='right_wheel'>
                <pose relative_to="chassis">-0.5 -0.6 0 -1.5707 0 0</pose>
                <inertial>
                    <mass>1</mass>
                    <inertia>
                        <ixx>0.043333</ixx>
                        <ixy>0</ixy>
                        <ixz>0</ixz>
                        <iyy>0.043333</iyy>
                        <iyz>0</iyz>
                        <izz>0.08</izz>
                    </inertia>
                </inertial>
                <visual name='visual'>
                    <geometry>
                        <cylinder>
                            <radius>0.4</radius>
                            <length>0.2</length>
                        </cylinder>
                    </geometry>
                    <material>
                        <ambient>1.0 0.0 0.0 1</ambient>
                        <diffuse>1.0 0.0 0.0 1</diffuse>
                        <specular>1.0 0.0 0.0 1</specular>
                    </material>
                </visual>
                <collision name='collision'>
                    <geometry>
                        <cylinder>
                            <radius>0.4</radius>
                            <length>0.2</length>
                        </cylinder>
                    </geometry>
                </collision>
            </link>
            <!-- frame is a named coordinate system, attached_to means it moves with the chassis during the whole simulation whereas
            relative_to is just for the initial pos, we couldve done without this frame by just putting the coordinates raw for caster's pos but this
            is more readable and can be reused later -->
            <frame name="caster_frame" attached_to='chassis'>
                <pose>0.8 0 -0.2 0 0 0</pose>
            </frame>
            <!-- front lone "wheel" is a sphere (children cart) -->
            <link name='caster'>
                <pose relative_to='caster_frame' />
                <inertial>
                    <mass>1</mass>
                    <inertia>
                        <ixx>0.016</ixx>
                        <ixy>0</ixy>
                        <ixz>0</ixz>
                        <iyy>0.016</iyy>
                        <iyz>0</iyz>
                        <izz>0.016</izz>
                    </inertia>
                </inertial>
                <visual name='visual'>
                    <geometry>
                        <sphere>
                            <radius>0.2</radius>
                        </sphere>
                    </geometry>
                    <material>
                        <ambient>0.0 1 0.0 1</ambient>
                        <diffuse>0.0 1 0.0 1</diffuse>
                        <specular>0.0 1 0.0 1</specular>
                    </material>
                </visual>
                <collision name='collision'>
                    <geometry>
                        <sphere>
                            <radius>0.2</radius>
                        </sphere>
                    </geometry>
                </collision>
            </link>

            <!-- connect links together using joints, revolute (like revolution, circular) allows rotation around only one axis -->
            <joint name='left_wheel_joint' type='revolute'>
                <pose relative_to='left_wheel' />
                <!-- where the connection happens, can only be 1 parent 1 child, child moves relative to parent -->
                <parent>chassis</parent>
                <child>left_wheel</child>
                <axis>
                    <xyz expressed_in='__model__'>0 1 0</xyz> <!-- wheel spins around Y, in the model's coordinate frame not wheel because
                    it's already rotated (up there, for the cylinder to look like a wheel) -->
                    <limit> <!-- rotation limits in radians, infinite for wheel, could be limited for steering wheel -->
                        <lower>-1.79769e+308</lower> <!-- negative infinity -->
                        <upper>1.79769e+308</upper> <!-- positive infinity -->
                    </limit>
                </axis>
            </joint>
            <joint name='right_wheel_joint' type='revolute'>
                <pose relative_to='right_wheel' />
                <parent>chassis</parent>
                <child>right_wheel</child>
                <axis>
                    <xyz expressed_in='__model__'>0 1 0</xyz>
                    <limit>
                        <lower>-1.79769e+308</lower>
                        <upper>1.79769e+308</upper>
                    </limit>
                </axis>
            </joint>
            <!-- type=ball gives 3 rotational degrees of freedom (fixed=no movement, universal=2 axes) -->
            <joint name='caster_wheel' type='ball'>
                <parent>chassis</parent>
                <child>caster</child>
            </joint>

            <!-- premade gazebo code to pilot a car using the joints and values up there, we put it within model for encapsulation as it's
            only related to it -->
            <plugin
                filename="gz-sim-diff-drive-system"
                name="gz::sim::systems::DiffDrive">
                <left_joint>left_wheel_joint</left_joint>
                <right_joint>right_wheel_joint</right_joint>
                <wheel_separation>1.2</wheel_separation>
                <wheel_radius>0.4</wheel_radius>
                <odom_publish_frequency>1</odom_publish_frequency> <!-- frequency at which the odometry is published at
                /model/vehicle_blue/odometry -->
                <topic>cmd_vel</topic> <!-- input <topic>, used in commands like 'gz topic -t "/cmd_vel" -m gz.msgs.Twist -p "linear: {x:
                0.5}, angular: {z: 0.05}" ' (after starting the sim) -->
            </plugin>

            <!-- TriggeredPublisher publishes a user specified message on an output topic in response to an input message that matches user
            specified criteria -->
            <plugin filename="gz-sim-triggered-publisher-system"
                name="gz::sim::systems::TriggeredPublisher">
                <input type="gz.msgs.Int32" topic="/keyboard/keypress">
                    <match field="data">16777234</match> <!-- left arrow key, as Int32 code, detected by /keyboard/keypress topic -->
                </input>
                <output type="gz.msgs.Twist" topic="/cmd_vel"> linear: {x: 0.0}, angular: {z: 0.5} <!-- send left movement to our /cmd_vel
                    set up above -->
                </output>
            </plugin>
            <!-- xml has no loops or convenient ways to handle such repetitions, unlike doing our own plugins in cpp, don't forget to
            activate Key Publisher plugin on the interface (top right) and start 'gz topic -e -t /keyboard/keypress' in another terminal  -->
            <plugin filename="gz-sim-triggered-publisher-system"
                name="gz::sim::systems::TriggeredPublisher">
                <input type="gz.msgs.Int32" topic="/keyboard/keypress">
                    <match field="data">16777235</match>
                </input>
                <output type="gz.msgs.Twist" topic="/cmd_vel">
                    linear: {x: 0.5}, angular: {z: 0.0}
                </output>
            </plugin>
            <plugin filename="gz-sim-triggered-publisher-system"
                name="gz::sim::systems::TriggeredPublisher">
                <input type="gz.msgs.Int32" topic="/keyboard/keypress">
                    <match field="data">16777236</match>
                </input>
                <output type="gz.msgs.Twist" topic="/cmd_vel">
                    linear: {x: 0.0}, angular: {z: -0.5}
                </output>
            </plugin>
            <plugin filename="gz-sim-triggered-publisher-system"
                name="gz::sim::systems::TriggeredPublisher">
                <input type="gz.msgs.Int32" topic="/keyboard/keypress">
                    <match field="data">16777237</match>
                </input>
                <output type="gz.msgs.Twist" topic="/cmd_vel">
                    linear: {x: -0.5}, angular: {z: 0.0}
                </output>
            </plugin>
            <!-- stop for collision (later) -->
            <plugin filename="gz-sim-triggered-publisher-system"
                name="gz::sim::systems::TriggeredPublisher">
                <input type="gz.msgs.Boolean" topic="/wall/touched">
                    <match>data: true</match>
                </input>
                <output type="gz.msgs.Twist" topic="/cmd_vel">
                    linear: {x: 0.0}, angular: {z: 0.0}
                </output>
            </plugin>
        </model>

        <!-- obstacle wall -->
        <model name='wall'>
            <static>true</static>
            <pose>5 0 0 0 0 0</pose> <!-- relative to world -->
            <link name='box'>
                <visual name='visual'>
                    <geometry>
                        <box>
                            <size>0.5 10.0 2.0</size>
                        </box>
                    </geometry>
                    <material>
                        <ambient>0.0 0.0 1.0 1</ambient>
                        <diffuse>0.0 0.0 1.0 1</diffuse>
                        <specular>0.0 0.0 1.0 1</specular>
                    </material>
                </visual>
                <collision name='collision'>
                    <geometry>
                        <box>
                            <size>0.5 10.0 2.0</size>
                        </box>
                    </geometry>
                </collision>
                <sensor name='sensor_contact' type='contact'>
                    <contact>
                        <collision>collision</collision>
                    </contact>
                </sensor>
            </link>
            <!-- enables contact/collision detection sensing on that specific link -->
            <plugin filename="gz-sim-contact-system"
                name="gz::sim::systems::Contact">
            </plugin>
            <!-- watches whether vehicle_blue is touching the wall -> publishes a boolean to a topic under the wall namespace -->
            <plugin filename="gz-sim-touchplugin-system"
                name="gz::sim::systems::TouchPlugin">
                <target>vehicle_blue</target>
                <namespace>wall</namespace>
                <time>0.001</time> <!-- minimum continuous contact duration in seconds before the TouchPlugin fires and publishes true -->
                <enabled>true</enabled>
            </plugin>
        </model>
    </world>
</sdf>