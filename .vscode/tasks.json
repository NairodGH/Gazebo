{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cmake build gz",
            "type": "shell",
            "command": "cd ${workspaceFolder}/src/avoid_wall && mkdir -p build && cd build && cmake .. && make -j$(nproc)",
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared", "focus": true },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "launch gz sim and node",
            "type": "shell",
            "command": "gz sim ${workspaceFolder}/src/avoid_wall/worlds/building_robot.sdf & sleep 3 && ${workspaceFolder}/src/avoid_wall/build/lidar_node_gz",
            "group": "test",
            "presentation": { "reveal": "always", "panel": "shared", "focus": true },
            "problemMatcher": []
        },
        {
            "label": "colcon build",
            "type": "shell",
            "command": "source /opt/ros/jazzy/setup.bash && cd ${workspaceFolder} && colcon build --packages-select avoid_wall",
            "group": { "kind": "build", "isDefault": true },
            "presentation": { "reveal": "always", "panel": "shared", "focus": true },
            "problemMatcher": []
        },
        {
            "label": "ros2 launch",
            "type": "shell",
            "command": "source /opt/ros/jazzy/setup.bash && source ${workspaceFolder}/install/avoid_wall/share/avoid_wall/local_setup.bash && ros2 launch avoid_wall my_launch.py",
            "group": "test",
            "presentation": { "reveal": "always", "panel": "shared", "focus": true },
            "problemMatcher": []
        },
        {
            "label": "build and launch (ros2)",
            "dependsOrder": "sequence",
            "dependsOn": ["colcon build", "ros2 launch"],
            "group": "test",
            "problemMatcher": []
        },
        {
            "label": "build and launch (gz)",
            "dependsOrder": "sequence",
            "dependsOn": ["cmake build gz", "launch gz sim and node"],
            "group": "test",
            "problemMatcher": []
        }
    ]
}